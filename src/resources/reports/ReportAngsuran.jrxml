	<property name="ireport.zoom" value="1.0"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<parameter name="LOGO_IMAGE" class="java.net.URL"/>
	<parameter name="TANGGAL_AWAL" class="java.sql.Date"/>
	<parameter name="TANGGAL_AKHIR" class="java.sql.Date"/>
	<parameter name="ORDER_ANGSURAN" class="java.lang.String"/>
	<queryString language="SQL">
		<![CDATA[SELECT
    ag.*,
    p.no_pinjaman,
    a.nama AS nama_anggota
FROM angsuran ag
INNER JOIN pinjaman p
    ON ag.id_pinjaman = p.id_pinjaman
INNER JOIN anggota a
    ON p.id_anggota = a.id_anggota
WHERE ($P{TANGGAL_AWAL} IS NULL OR ag.tanggal_bayar >= $P{TANGGAL_AWAL})
  AND ($P{TANGGAL_AKHIR} IS NULL OR ag.tanggal_bayar <= $P{TANGGAL_AKHIR})
ORDER BY $P!{ORDER_ANGSURAN};]]>
	</queryString>
	<field name="no_pinjaman" class="java.lang.String">
		<fieldDescription><![CDATA[]]></fieldDescription>
	</field>
	<field name="nama_anggota" class="java.lang.String"/>
	<field name="angsuran_ke" class="java.lang.Integer">
		<fieldDescription><![CDATA[]]></fieldDescription>
	</field>
