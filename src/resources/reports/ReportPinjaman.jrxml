	<property name="ireport.zoom" value="1.0"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<parameter name="LOGO_IMAGE" class="java.net.URL"/>
	<parameter name="TANGGAL_AWAL" class="java.sql.Date"/>
	<parameter name="TANGGAL_AKHIR" class="java.sql.Date"/>
	<parameter name="ORDER_PINJAMAN" class="java.lang.String"/>
	<queryString language="SQL">
		<![CDATA[SELECT
    p.*,
    a.nama AS nama_anggota
FROM pinjaman p
INNER JOIN anggota a
    ON p.id_anggota = a.id_anggota
WHERE ($P{TANGGAL_AWAL} IS NULL OR p.tanggal_pinjaman >= $P{TANGGAL_AWAL})
  AND ($P{TANGGAL_AKHIR} IS NULL OR p.tanggal_pinjaman <= $P{TANGGAL_AKHIR})
ORDER BY $P!{ORDER_PINJAMAN};]]>
	</queryString>
	<field name="nama_anggota" class="java.lang.String"/>
	<field name="tanggal_pinjaman" class="java.sql.Date">
		<fieldDescription><![CDATA[]]></fieldDescription>
	</field>
	<field name="jumlah_pinjaman" class="java.math.BigDecimal">
		<fieldDescription><![CDATA[]]></fieldDescription>
	</field>
	<field name="tenor_bulan" class="java.lang.Integer">
		<fieldDescription><![CDATA[]]></fieldDescription>
	</field>
	<field name="bunga_persen" class="java.math.BigDecimal">
		<fieldDescription><![CDATA[]]></fieldDescription>
	</field>
	<variable name="Total" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{jumlah_pinjaman}]]></variableExpression>
	</variable>
