<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="null" language="groovy" pageWidth="595" pageHeight="842" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="5df923fb-ae00-4042-8fbc-696c7f41ba2e">
	<property name="ireport.zoom" value="1.0"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<parameter name="TANGGAL_AWAL" class="java.sql.Date"/>
	<parameter name="TANGGAL_AKHIR" class="java.sql.Date"/>
	<parameter name="ORDER_TRANSAKSI" class="java.lang.String"/>
	<queryString language="SQL">
		<![CDATA[SELECT
    t.id_transaksi,
    t.tanggal,
    COALESCE(p.no_pinjaman, '-') AS no_pinjaman,
    a.nama AS nama_anggota,
    t.jenis_transaksi,
    CASE
        WHEN t.debet > 0 THEN t.debet
        ELSE t.kredit
    END AS nominal,
    t.keterangan
FROM transaksi t
LEFT JOIN anggota a
    ON t.id_anggota = a.id_anggota
LEFT JOIN pinjaman p
    ON t.referensi_tabel = 'pinjaman'
    AND t.referensi_id = p.id_pinjaman
WHERE ($P{TANGGAL_AWAL} IS NULL OR DATE(t.tanggal) >= $P{TANGGAL_AWAL})
  AND ($P{TANGGAL_AKHIR} IS NULL OR DATE(t.tanggal) <= $P{TANGGAL_AKHIR})
ORDER BY $P!{ORDER_TRANSAKSI};]]>
	</queryString>
	<field name="tanggal" class="java.sql.Timestamp">
		<fieldDescription><![CDATA[]]></fieldDescription>
	</field>
	<field name="nama_anggota" class="java.lang.String"/>
	<field name="jenis_transaksi" class="java.lang.String">
		<fieldDescription><![CDATA[]]></fieldDescription>
	</field>
	<field name="nominal" class="java.math.BigDecimal"/>
