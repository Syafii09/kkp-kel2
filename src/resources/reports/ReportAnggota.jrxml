	<parameter name="TANGGAL_AWAL" class="java.sql.Date"/>
	<parameter name="TANGGAL_AKHIR" class="java.sql.Date"/>
	<parameter name="ORDER_ANGGOTA" class="java.lang.String"/>
	<queryString language="SQL">
		<![CDATA[SELECT *
FROM anggota
WHERE ($P{TANGGAL_AWAL} IS NULL OR tanggal_daftar >= $P{TANGGAL_AWAL})
  AND ($P{TANGGAL_AKHIR} IS NULL OR tanggal_daftar <= $P{TANGGAL_AKHIR})
ORDER BY $P!{ORDER_ANGGOTA};]]>
	</queryString>
